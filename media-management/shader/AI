# code_executor.py
import subprocess
from config import TEMP_SCRIPT_FILENAME, TEMP_LOG_FILENAME

def execute_code(code, filename=TEMP_SCRIPT_FILENAME):
    try:
        with open(filename, "w") as f:
            f.write(code)
        process = subprocess.run(["python", filename], capture_output=True, text=True, check=False)
        stdout = process.stdout
        stderr = process.stderr
        with open(TEMP_LOG_FILENAME, "w") as log_file:
            log_file.write(f"Standard Output:\n{stdout}\nStandard Error:\n{stderr}")
        return stdout, stderr
    except Exception as e:
        with open(TEMP_LOG_FILENAME, "w") as log_file:
            log_file.write(f"Error during execution: {str(e)}")
        return "", str(e)

if __name__ == '__main__':
    test_code = """print("Testing code execution")
print(5/0)
"""
    stdout, stderr = execute_code(test_code)
    print("Standard Output:\n", stdout)
    print("Standard Error:\n", stderr)
    with open(TEMP_LOG_FILENAME, "r") as f:
        log_content = f.read()
        print("\nLog File Content:\n", log_content)
